{
  "name": "blazeplot",
  "version": "0.3.1",
  "author": {
    "name": "Federico Cervelli",
    "url": "https://cervelli.dev"
  },
  "homepage": "https://cervelli.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Federicocervelli/blazeplot.git"
  },
  "description": "Real-time LOD time series rendering engine for the browser.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./linked": {
      "types": "./dist/linked.d.ts",
      "import": "./dist/linked.js"
    },
    "./plugins/legend": {
      "types": "./dist/plugins/legend.d.ts",
      "import": "./dist/plugins/legend.js"
    },
    "./plugins/tooltip": {
      "types": "./dist/plugins/tooltip.d.ts",
      "import": "./dist/plugins/tooltip.js"
    },
    "./plugins/interactions": {
      "types": "./dist/plugins/interactions.d.ts",
      "import": "./dist/plugins/interactions.js"
    },
    "./plugins/annotations": {
      "types": "./dist/plugins/annotations.d.ts",
      "import": "./dist/plugins/annotations.js"
    },
    "./plugins/selection": {
      "types": "./dist/plugins/selection.d.ts",
      "import": "./dist/plugins/selection.js"
    },
    "./plugins/crosshair": {
      "types": "./dist/plugins/crosshair.d.ts",
      "import": "./dist/plugins/crosshair.js"
    },
    "./plugins/navigator": {
      "types": "./dist/plugins/navigator.d.ts",
      "import": "./dist/plugins/navigator.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "ci": "bun run typecheck && bun test && bun run build",
    "build:js": "vite build --mode js-only",
    "pages:build": "vite build --config vite.pages.config.ts",
    "preview": "vite preview",
    "bench": "bun scripts/benchmark.ts",
    "bench:scatter": "bun scripts/scatter-profile.ts",
    "bench:report": "bun scripts/benchmark-report.ts",
    "docs:readme": "bun run build && node scripts/generate-readme-docs.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "regl": "^2.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0"
  }
}
