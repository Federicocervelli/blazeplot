{
  "name": "blazeplot",
  "version": "0.3.5",
  "packageManager": "bun@1.3.14",
  "description": "Real-time LOD time series rendering engine for the browser.",
  "keywords": [
    "webgl2",
    "chart",
    "charts",
    "plotting",
    "data-visualization",
    "time-series",
    "realtime",
    "streaming",
    "dashboard",
    "react"
  ],
  "author": {
    "name": "Federico Cervelli",
    "url": "https://cervelli.dev"
  },
  "homepage": "https://blazeplot.cervelli.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Federicocervelli/blazeplot.git"
  },
  "bugs": {
    "url": "https://github.com/Federicocervelli/blazeplot/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "import": "./dist/interaction.js"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./linked": {
      "types": "./dist/linked.d.ts",
      "import": "./dist/linked.js"
    },
    "./linked-core": {
      "types": "./dist/linked-core.d.ts",
      "import": "./dist/linked-core.js"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    },
    "./plugins/legend": {
      "types": "./dist/plugins/legend.d.ts",
      "import": "./dist/plugins/legend.js"
    },
    "./plugins/tooltip": {
      "types": "./dist/plugins/tooltip.d.ts",
      "import": "./dist/plugins/tooltip.js"
    },
    "./plugins/interactions": {
      "types": "./dist/plugins/interactions.d.ts",
      "import": "./dist/plugins/interactions.js"
    },
    "./plugins/annotations": {
      "types": "./dist/plugins/annotations.d.ts",
      "import": "./dist/plugins/annotations.js"
    },
    "./plugins/selection": {
      "types": "./dist/plugins/selection.d.ts",
      "import": "./dist/plugins/selection.js"
    },
    "./plugins/crosshair": {
      "types": "./dist/plugins/crosshair.d.ts",
      "import": "./dist/plugins/crosshair.js"
    },
    "./plugins/navigator": {
      "types": "./dist/plugins/navigator.d.ts",
      "import": "./dist/plugins/navigator.js"
    },
    "./plugins/flamegraph": {
      "types": "./dist/plugins/flamegraph.d.ts",
      "import": "./dist/plugins/flamegraph.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "BLAZEPLOT_PAGES_BASE=/ vite --config vite.pages.config.ts",
    "legacy-preview:dev": "vite",
    "build": "vite build",
    "bench:ci": "bun run bench --scenario ci-smoke --measure-ms 500 --warmup-ms 100 --width 800 --height 450 --top 12 --setup-timeout-ms 60000",
    "ci": "bun run typecheck && bun test && bun run build && bun run test:exports && bun run test:package && bun run test:bundle-size && bun run bench:ci && bun run test:visual && bun run test:interaction",
    "build:js": "vite build --mode js-only",
    "pages:build": "vite build --config vite.pages.config.ts",
    "pages:preview": "vite preview --config vite.pages.config.ts",
    "preview": "vite preview",
    "bench": "bun scripts/benchmark.ts",
    "bench:scatter": "bun scripts/scatter-profile.ts",
    "bench:report": "bun scripts/benchmark-report.ts",
    "release:benchmarks": "bun scripts/release-benchmarks.ts",
    "docs:bundle-size": "bun scripts/bundle-size-check.ts --markdown",
    "bundle:analyze": "bun scripts/bundle-analyze.ts",
    "docs:readme": "bun run build && node scripts/generate-readme-docs.js",
    "test": "bun test",
    "test:visual": "bun scripts/visual-test.ts",
    "test:exports": "bun scripts/package-export-smoke.ts",
    "test:package": "bun pm pack --dry-run",
    "test:bundle-size": "bun scripts/bundle-size-check.ts",
    "typecheck": "tsc --noEmit",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "test:interaction": "bun scripts/interaction-test.ts"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "highlight.js": "^11.11.1",
    "lit": "^3.3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0"
  }
}
